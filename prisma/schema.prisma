generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  AREA_MANAGER
  STORE_MANAGER
  SHIFT_LEAD
  STAFF
}

enum LocationType {
  CAFE
  ROASTERY
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum TrainingCategory {
  COFFEE
  SERVICE
  SAFETY
  LEADERSHIP
  ROASTERY
}

enum DocumentStatus {
  MISSING
  PENDING
  COMPLETE
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  FULFILLED
  REJECTED
}

enum InventoryUnit {
  EACH
  CASE
  POUND
  OUNCE
  GALLON
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(STAFF)
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id])
  employee      Employee?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  type            LocationType
  users           User[]
  employees       Employee[]
  scheduleShifts  ScheduleShift[]
  inventoryItems  InventoryItem[]
  orderRequests   OrderRequest[]
  createdAt       DateTime         @default(now())
}

model Employee {
  id             String                @id @default(cuid())
  userId         String?               @unique
  user           User?                 @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  email          String                @unique
  phone          String?
  role           Role
  status         EmployeeStatus        @default(ACTIVE)
  title          String
  hireDate       DateTime
  locationId     String
  location       Location              @relation(fields: [locationId], references: [id])
  scheduleShifts ScheduleShift[]
  documents      EmployeeDocument[]
  quizAttempts   QuizAttempt[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model ScheduleShift {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  startsAt   DateTime
  endsAt     DateTime
  position   String
  notes      String?
}

model TrainingMaterial {
  id          String           @id @default(cuid())
  title       String           @unique
  category    TrainingCategory
  summary     String
  contentUrl  String
  requiredFor Role[]
  quiz        Quiz?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Quiz {
  id                 String             @id @default(cuid())
  trainingMaterialId String             @unique
  trainingMaterial   TrainingMaterial   @relation(fields: [trainingMaterialId], references: [id])
  title              String
  passingScore       Int                @default(80)
  questions          QuizQuestion[]
  attempts           QuizAttempt[]
}

model QuizQuestion {
  id        String   @id @default(cuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  prompt    String
  choices   String[]
  answer    String

  @@unique([quizId, prompt])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  quizId     String
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  score      Int
  passed     Boolean
  takenAt    DateTime @default(now())
}

model HrDocumentTemplate {
  id          String             @id @default(cuid())
  name        String
  description String
  required    Boolean            @default(true)
  documents   EmployeeDocument[]
}

model EmployeeDocument {
  id         String             @id @default(cuid())
  employeeId String
  employee   Employee           @relation(fields: [employeeId], references: [id])
  templateId String
  template   HrDocumentTemplate @relation(fields: [templateId], references: [id])
  status     DocumentStatus     @default(MISSING)
  completedAt DateTime?

  @@unique([employeeId, templateId])
}

model InventoryItem {
  id          String        @id @default(cuid())
  name        String
  category    String
  unit        InventoryUnit
  parLevel    Int
  currentQty  Int
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id])
  orderLines  OrderLine[]
  updatedAt   DateTime      @updatedAt

  @@unique([locationId, name])
}

model OrderRequest {
  id          String      @id @default(cuid())
  requestNo   String      @unique
  locationId  String
  location    Location    @relation(fields: [locationId], references: [id])
  requestedBy String
  status      OrderStatus @default(SUBMITTED)
  notes       String?
  lines       OrderLine[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderLine {
  id             String       @id @default(cuid())
  orderRequestId String
  orderRequest   OrderRequest @relation(fields: [orderRequestId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Int

  @@unique([orderRequestId, inventoryItemId])
}
